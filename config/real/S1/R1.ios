hostname S1R1

ip routing

interface GigabitEthernet0/0/1
 no shutdown

 ! ================= VLAN 10 =================
interface GigabitEthernet0/0/0.10
 encapsulation dot1Q 10
 ip address 192.168.10.2 255.255.255.0
 standby 10 ip 192.168.10.1
 standby 10 priority 100
 standby 10 preempt

 ! ================= VLAN 20 =================
interface GigabitEthernet0/0/0.20
 encapsulation dot1Q 20
 ip address 192.168.20.2 255.255.255.0
 standby 20 ip 192.168.20.1
 standby 20 priority 100
 standby 20 preempt

 ! =========== VLAN 88 (Management) ===========
interface GigabitEthernet0/0/0.88
 encapsulation dot1Q 88
 ip address 192.168.88.1 255.255.255.0

 ! ================= VLAN 99 =================
interface GigabitEthernet0/0/0.99
 encapsulation dot1Q 99
 ip address 192.168.99.2 255.255.255.0
 standby 99 ip 192.168.99.1
 standby 99 priority 100
 standby 99 preempt

 ! S2R1
int tun 0
 ip addr 10.0.1.1 255.255.255.252
 tun sour g0/0/1
 tun dest 203.0.113.14

 ! S3R1
int tun 1
 ip addr 10.0.2.1 255.255.255.252
 tun sour g0/0/1
 tun dest 203.0.113.22

 ! BGP
router bgp 65001
 bgp log-neighbor-changes
 no synchronization
 neighbor 10.0.1.2 remote-as 65002
 neighbor 10.0.2.2 remote-as 65003
 network 192.168.10.0
 network 192.168.20.0
 network 192.168.99.0

ip domain-name gls.local

crypto key generate rsa modulus 2048
ip ssh version 2

username class privilege 15 secret cisco

line vty 0 4
 transport input ssh
 login local
 exec-timeout 10 0

service password-encryption