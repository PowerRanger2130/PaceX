hostname S2R1

ip routing

interface GigabitEthernet0/0/0
 no shutdown
 ip address dhcp

 ! =========== VLAN 82 (Management) ===========
interface GigabitEthernet0/0/1.82
 encapsulation dot1Q 82
 ip address 192.168.82.1 255.255.255.224
 ip access-group VLAN82_IN in

 ! ================= VLAN 199 =================
interface GigabitEthernet0/0/1.199
 encapsulation dot1Q 199
 ip address 192.168.199.1 255.255.255.0
 ip access-group VLAN199_IN in

 ! S1R1
int tun 0
 ip addr 10.0.1.2 255.255.255.252
 tun sour g0/0/0
 ! Tunnel to S1R1
 tun dest 10.224.55.37

 ! BGP
router bgp 65002
 bgp log-neighbor-changes
 no synchronization
 neighbor 10.0.1.1 remote-as 65001
 network 192.168.82.0 mask 255.255.255.224
 network 192.168.199.0
 exit

ip domain name gls.local

crypto key generate rsa modulus 2048
ip ssh version 2

username class privilege 15 secret cisco

 ! ACL
ip access-list extended VLAN82_IN
 permit ip 192.168.82.0 0.0.0.31 192.168.81.0 0.0.0.31
 permit ip 192.168.82.0 0.0.0.31 192.168.83.0 0.0.0.31
 permit ip any any

ip access-list extended VLAN199_IN
 deny ip 192.168.199.0 0.0.0.255 192.168.81.0 0.0.0.31
 deny ip 192.168.199.0 0.0.0.255 192.168.82.0 0.0.0.31
 deny ip 192.168.199.0 0.0.0.255 192.168.83.0 0.0.0.31
 permit ip any any

ip access-list standard MGMT
 permit 192.168.81.0 0.0.0.31
 permit 192.168.82.0 0.0.0.31
 permit 192.168.83.0 0.0.0.31

line vty 0 4
 transport input ssh
 login local
 exec-timeout 10 0
 access-class MGMT in

service password-encryption