hostname S3R1

ip routing

interface GigabitEthernet0/0/1
 ip address dhcp
 ip nat outside
 no shutdown

 ! =========== VLAN 83 (Management) ===========
interface GigabitEthernet0/0/0.83
 encapsulation dot1Q 83
 ip address 192.168.83.1 255.255.255.224
 ip access-group VLAN83_IN in
 ip nat inside

 ! ================= VLAN 32 =================
interface GigabitEthernet0/0/0
 ip address 192.168.32.1 255.255.255.0
 ip access-group VLAN32_IN in
 ip nat inside

 ! S1R1
int tun 0
 ip addr 10.0.2.2 255.255.255.252
 tun sour g0/0/1
 ! Tunnel to S1R1
 tun dest 10.224.55.37

 ! BGP
router bgp 65003
 bgp log-neighbor-changes
 no synchronization
 neighbor 10.0.2.1 remote-as 65001
 network 192.168.32.0
 network 192.168.83.0 mask 255.255.255.224

ip domain name gls.local

crypto key generate rsa modulus 2048
ip ssh version 2

username class privilege 15 secret cisco

ip nat inside source list NAT_INSIDE interface GigabitEthernet0/0/0 overload

 ! ACL
ip access-list standard NAT_INSIDE
 permit 192.168.83.0 0.0.0.31
 permit 192.168.32.0 0.0.0.255

ip access-list extended VLAN83_IN
 permit ip 192.168.83.0 0.0.0.31 192.168.81.0 0.0.0.31
 permit ip 192.168.83.0 0.0.0.31 192.168.82.0 0.0.0.31
 deny ip 192.168.83.0 0.0.0.31 any
 permit ip any any

ip access-list extended VLAN32_IN
 deny ip 192.168.32.0 0.0.0.255 192.168.81.0 0.0.0.31
 deny ip 192.168.32.0 0.0.0.255 192.168.82.0 0.0.0.31
 deny ip 192.168.32.0 0.0.0.255 192.168.83.0 0.0.0.31
 permit ip any any

ip access-list standard MGMT
 permit 192.168.81.0 0.0.0.31
 permit 192.168.82.0 0.0.0.31
 permit 192.168.83.0 0.0.0.31

line vty 0 4
 transport input ssh
 login local
 exec-timeout 10 0
 access-class MGMT in

service password-encryption